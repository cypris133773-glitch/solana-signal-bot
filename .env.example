# ── Solana Signal Bot Config ──

# Telegram (get from @BotFather)
TELEGRAM_BOT_TOKEN=7123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Birdeye (free: https://bds.birdeye.so → sign up → API Keys)
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Filters (optional, these are defaults) ──
MIN_LIQUIDITY=5000
MAX_LIQUIDITY=100000
MIN_VOLUME_5M=1000
MIN_BUY_COUNT=10
MAX_TOP_HOLDER=30
ALERT_COOLDOWN=30
